# Supabase Configuration
# Get these values from your Supabase project dashboard -> Settings -> API

# Required: Your Supabase project URL
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co

# Required: Your Supabase anonymous/public key (safe to expose in browser)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Optional: Service role key for admin operations (DO NOT expose this in browser)
# Only use this in server-side code (API routes, Server Components)
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here


# Gmail SMTP for Contact Form
EMAIL_USER=Bakeryblissindia@gmail.com
EMAIL_APP_PASSWORD=jhbhbnkjhnkjhkjhnkjkjnkjkjkjhkan

# Razorpay Payment Gateway
# Get these from https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_key_secret_here
